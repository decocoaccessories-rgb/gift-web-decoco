# Supabase - get from https://supabase.com/dashboard/project/_/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Resend - get from https://resend.com/api-keys
RESEND_API_KEY=re_your-api-key-here

# Email — FROM must use a domain verified at https://resend.com/domains
RESEND_FROM_EMAIL=noreply@trangsucdecoco.vn
ADMIN_EMAIL=admin@decoco.vn
NOTIFICATION_EMAIL=decoco.cskh@gmail.com

# App URL (used for links in emails and as VNPAY return base)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# VNPAY - sandbox by default. Get TMN code & secret from https://sandbox.vnpayment.vn
VNPAY_TMN_CODE=
VNPAY_HASH_SECRET=
VNPAY_HOST=https://sandbox.vnpayment.vn
VNPAY_RETURN_PATH=/api/payments/vnpay/return

# VietQR (SePay) auto-confirm — đăng ký tại https://my.sepay.vn, webhook docs: https://docs.sepay.vn
# Tài khoản nhận tiền + tên ngân hàng (mã ngắn SePay, vd: MBBank, Vietcombank, ACB).
SEPAY_BANK_ACCOUNT_NUMBER=
SEPAY_BANK_NAME=
# API key cấu hình ở SePay -> Webhooks (gửi qua header Authorization: Apikey <secret>).
SEPAY_WEBHOOK_SECRET=
VIETQR_DEFAULT_EXPIRE_MINUTES=15
# Bật lựa chọn VietQR ở trang đặt hàng (chỉ bật khi đã cấu hình SePay xong).
NEXT_PUBLIC_VIETQR_ENABLED=false
